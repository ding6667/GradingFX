<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.javascene.gradingfx.controller.MainController"
            stylesheets="@styles.css"
            prefWidth="1200" prefHeight="800">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <padding>
                <Insets bottom="14" left="24" right="24" top="14"/>
            </padding>
            <Label text="作业批阅工作台" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="导出路径配置" fx:id="exportConfigBtn" styleClass="button"
                    onAction="#handleOpenExportConfig"/>
            <Button text="评分标准" fx:id="standardBtn" styleClass="button"
                    onAction="#handleOpenStandard"/>
            <Button text="历史记录" fx:id="historyBtn" styleClass="button"
                    onAction="#handleOpenHistory"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="12" prefWidth="280" style="-fx-padding: 12; -fx-background-color: #F7F8FA;">
            <!-- Upload area -->
            <Label text="上传文件" styleClass="subtitle"/>
            <StackPane fx:id="uploadArea" styleClass="upload-area"
                       VBox.vgrow="NEVER" prefHeight="120"
                       onDragOver="#handleDragOver"
                       onDragDropped="#handleDrop"
                       onDragEntered="#handleDragEntered"
                       onDragExited="#handleDragExited"
                       onMouseClicked="#handleUploadClick">
                <VBox alignment="CENTER" spacing="6">
                    <Label text="&#128194;" style="-fx-font-size: 28px; -fx-text-fill: #1890FF;"/>
                    <Label text="拖拽 ZIP 包至此" wrapText="true"
                           style="-fx-font-size: 13px; -fx-font-weight: 500; -fx-text-fill: #434343;"/>
                    <Label text="或点击选择文件" style="-fx-font-size: 11px; -fx-text-fill: #BFBFBF;"/>
                </VBox>
            </StackPane>

            <VBox fx:id="selectedFilesArea" styleClass="card" VBox.vgrow="NEVER" visible="false" managed="false"
                  style="-fx-min-height: 120px;">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <spacing>6</spacing>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="&#128206; 已选中文件" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #1890FF;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="清除" fx:id="clearFilesBtn" styleClass="secondary-button"
                            onAction="#handleClearFiles" style="-fx-font-size: 12px; -fx-padding: 4px 10px;"/>
                </HBox>
                <ListView fx:id="selectedFilesList" prefHeight="80" VBox.vgrow="ALWAYS"/>
            </VBox>

            <Label text="学生列表" styleClass="subtitle"/>
            <TreeView fx:id="studentTree" VBox.vgrow="ALWAYS" prefHeight="400"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" style="-fx-padding: 0 12 12 0; -fx-background-color: #F7F8FA;">
            <HBox spacing="12">
                <VBox styleClass="stat-card" prefWidth="180">
                    <Label text="总人数" styleClass="secondary"/>
                    <Label fx:id="totalLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #1890FF;"/>
                </VBox>
                <VBox styleClass="stat-card-green" prefWidth="180">
                    <Label text="已完成" styleClass="secondary"/>
                    <Label fx:id="completedLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #52C41A;"/>
                </VBox>
                <VBox styleClass="stat-card-red" prefWidth="180">
                    <Label text="失败" styleClass="secondary"/>
                    <Label fx:id="failedLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #FF4D4F;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 8px 14px;">
                <Label text="批阅进度" style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #8C8C8C;"/>
                <ProgressBar fx:id="progressBar" progress="0.0" prefHeight="6" prefWidth="200"
                             HBox.hgrow="ALWAYS" style="-fx-accent: #52C41A;"/>
                <Label fx:id="progressLabel" text="0%"
                       style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #52C41A;"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 4px 0;">
                <Button text="开始批阅" fx:id="startBtn" styleClass="primary-button"
                        onAction="#handleStart"/>
                <Button text="暂停" fx:id="pauseBtn" styleClass="secondary-button"
                        onAction="#handlePause"/>
                <Button text="继续" fx:id="resumeBtn" styleClass="secondary-button"
                        onAction="#handleResume"/>
                <Button text="重试失败项" fx:id="retryBtn" styleClass="secondary-button"
                        onAction="#handleRetry"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="查看结果详情" fx:id="detailBtn" styleClass="secondary-button"
                        onAction="#handleViewDetail"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="resultTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="studentIdColumn" text="学号" prefWidth="100" sortable="true"/>
                        <TableColumn fx:id="studentNameColumn" text="姓名" prefWidth="80" sortable="true"/>
                        <TableColumn fx:id="rawScoreColumn" text="AI评分" prefWidth="70" sortable="true"/>
                        <TableColumn fx:id="aiCommentColumn" text="AI评语" prefWidth="200" sortable="false"/>
                        <TableColumn fx:id="teacherScoreColumn" text="教师评分" prefWidth="80" sortable="true"/>
                        <TableColumn fx:id="teacherCommentColumn" text="教师评语" prefWidth="200" sortable="false"/>
                        <TableColumn fx:id="teacherNoteColumn" text="教师备注" prefWidth="150" sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #F0F0F0; -fx-border-width: 1px 0 0 0;">
            <padding>
                <Insets bottom="10" left="20" right="20" top="10"/>
            </padding>
            <Button text="导出 Excel" fx:id="exportExcelBtn" styleClass="primary-button"
                    onAction="#handleExportExcel"/>
            <Button text="导出 Word" fx:id="exportWordBtn" styleClass="primary-button"
                    onAction="#handleExportWord"/>
        </HBox>
    </bottom>

</BorderPane>
