<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.javascene.gradingfx.controller.MainController"
            stylesheets="@styles.css"
            prefWidth="1200" prefHeight="800">

    <!-- Top: Header bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="card">
            <padding>
                <Insets bottom="12" left="24" right="24" top="12"/>
            </padding>
            <Label text="作业批阅工作台" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="评分标准" fx:id="standardBtn" styleClass="secondary-button"
                    onAction="#handleOpenStandard"/>
            <Button text="历史记录" fx:id="historyBtn" styleClass="secondary-button"
                    onAction="#handleOpenHistory"/>
        </HBox>
    </top>

    <!-- Left: Upload and student tree -->
    <left>
        <VBox spacing="12" prefWidth="280" style="-fx-padding: 12;">
            <!-- Upload area -->
            <Label text="上传文件" styleClass="subtitle"/>
            <StackPane fx:id="uploadArea" styleClass="upload-area"
                       VBox.vgrow="NEVER" prefHeight="120">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="📄" style="-fx-font-size: 28px;"/>
                    <Label text="拖拽 ZIP 包至此" wrapText="true" style="-fx-font-size: 12px;"/>
                    <Label text="或点击选择文件" styleClass="secondary" style="-fx-font-size: 11px;"/>
                </VBox>
            </StackPane>

            <!-- Student tree -->
            <Label text="学生列表" styleClass="subtitle"/>
            <TreeView fx:id="studentTree" VBox.vgrow="ALWAYS" prefHeight="400"/>
        </VBox>
    </left>

    <!-- Center: Statistics and results -->
    <center>
        <VBox spacing="10" style="-fx-padding: 0 12 12 0;">
            <!-- Statistics cards -->
            <HBox spacing="12">
                <VBox styleClass="card" prefWidth="180">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                    <Label text="总人数" styleClass="secondary" style="-fx-font-size: 12px;"/>
                    <Label fx:id="totalLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #4F46E5;"/>
                </VBox>
                <VBox styleClass="card" prefWidth="180">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                    <Label text="已完成" styleClass="secondary" style="-fx-font-size: 12px;"/>
                    <Label fx:id="completedLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #10B981;"/>
                </VBox>
                <VBox styleClass="card" prefWidth="180">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                    <Label text="失败" styleClass="secondary" style="-fx-font-size: 12px;"/>
                    <Label fx:id="failedLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #EF4444;"/>
                </VBox>
            </HBox>

            <!-- Progress -->
            <VBox spacing="4" styleClass="card">
                <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="批阅进度:" style="-fx-font-size: 13px;"/>
                    <Label fx:id="progressLabel" text="0%" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #4F46E5;"/>
                </HBox>
                <ProgressBar fx:id="progressBar" progress="0.0" prefHeight="6"/>
            </VBox>

            <!-- Control buttons -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="开始批阅" fx:id="startBtn" styleClass="primary-button"
                        onAction="#handleStart"/>
                <Button text="暂停" fx:id="pauseBtn" styleClass="secondary-button"
                        onAction="#handlePause"/>
                <Button text="继续" fx:id="resumeBtn" styleClass="secondary-button"
                        onAction="#handleResume"/>
                <Button text="重试失败项" fx:id="retryBtn" styleClass="secondary-button"
                        onAction="#handleRetry"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="查看结果详情" fx:id="detailBtn" styleClass="secondary-button"
                        onAction="#handleViewDetail"/>
            </HBox>

            <!-- Results table -->
            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="resultTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="学号" prefWidth="120" sortable="true"/>
                        <TableColumn fx:id="nameColumn" text="姓名" prefWidth="80" sortable="true"/>
                        <TableColumn fx:id="scoreColumn" text="得分" prefWidth="80" sortable="true"/>
                        <TableColumn fx:id="commentColumn" text="评语缩略" prefWidth="300" sortable="false"/>
                        <TableColumn fx:id="statusColumn" text="状态" prefWidth="120" sortable="true"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- Bottom: Export buttons -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="card">
            <padding>
                <Insets bottom="10" left="20" right="20" top="10"/>
            </padding>
            <Button text="导出 Excel" fx:id="exportExcelBtn" styleClass="primary-button"
                    onAction="#handleExportExcel"/>
            <Button text="导出 Word" fx:id="exportWordBtn" styleClass="primary-button"
                    onAction="#handleExportWord"/>
        </HBox>
    </bottom>

</BorderPane>
